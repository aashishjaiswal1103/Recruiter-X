{
  "name": "hack",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run next-dev\" \"npm run fastapi-dev\"",
    "next-dev": "next dev",
    "fastapi-dev": "python -m uvicorn api.index:app --reload",
    "worker": "celery -A api.celery_app worker --loglevel=info -Q parse,analyze,report,priority",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tanstack/react-query": "^5.101.1",
    "lucide-react": "^1.21.0",
    "next": "14.2.4",
    "react": "^18",
    "react-dom": "^18",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.80.0",
    "recharts": "^3.9.0",
    "sonner": "^2.0.7",
    "zod": "^4.4.3",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "concurrently": "^8.2.2",
    "eslint": "^8",
    "eslint-config-next": "14.2.4",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
