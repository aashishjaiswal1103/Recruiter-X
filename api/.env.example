# Recruiter-X Backend Environment Variables
ENVIRONMENT=development

# Supabase Configurations
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# Redis Cache and Queue Configurations
# Example: redis://default:password@localhost:6379 or rediss://default:password@upstash-url:6379
REDIS_URL=redis://localhost:6379

# BYOK Key Encryption Master Secret
# Must be a secure 32-byte key for AES-GCM (base64 encoded or raw string)
MASTER_ENCRYPTION_SECRET=your_secure_master_encryption_secret_here

# Sentry Monitoring (Optional for PoC)
SENTRY_DSN=
